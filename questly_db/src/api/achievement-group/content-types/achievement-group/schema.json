{
  "kind": "collectionType",
  "collectionName": "achievement_groups",
  "info": {
    "singularName": "achievement-group",
    "pluralName": "achievement-groups",
    "displayName": "achievement-group"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "game": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::game.game"
    },
    "icon": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "uuid": {
      "type": "customField",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "customField": "plugin::strapi-advanced-uuid.uuid",
      "options": {
        "disable-auto-fill": true,
        "uuid-format": "^Ag[a-zA-Z0-9]{4}$"
      }
    }
  }
}
