{
  "kind": "collectionType",
  "collectionName": "items",
  "info": {
    "singularName": "item",
    "pluralName": "items",
    "displayName": "item"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "weapon",
        "armor",
        "consumable",
        "material",
        "other"
      ]
    },
    "amount": {
      "type": "integer"
    },
    "price": {
      "type": "integer"
    },
    "description": {
      "type": "richtext"
    },
    "rarity": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::rarity.rarity"
    },
    "game": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::game.game"
    }
  }
}
