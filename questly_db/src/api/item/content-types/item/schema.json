{
  "kind": "collectionType",
  "collectionName": "items",
  "info": {
    "singularName": "item",
    "pluralName": "items",
    "displayName": "item"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "amount": {
      "type": "integer"
    },
    "price": {
      "type": "integer"
    },
    "description": {
      "type": "richtext"
    },
    "rarity": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::rarity.rarity"
    },
    "game": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::game.game"
    },
    "level": {
      "type": "integer"
    },
    "effects": {
      "type": "richtext"
    },
    "armor": {
      "type": "integer"
    },
    "damage": {
      "type": "integer"
    },
    "console_id": {
      "type": "string"
    },
    "uuid": {
      "type": "customField",
      "customField": "plugin::strapi-advanced-uuid.uuid",
      "options": {
        "uuid-format": "^I[a-zA-Z0-9]{5}$"
      }
    },
    "item_type": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::item-type.item-type"
    },
    "missable": {
      "type": "boolean"
    },
    "dlc": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::dlc.dlc"
    }
  }
}
