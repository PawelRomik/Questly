{
  "kind": "collectionType",
  "collectionName": "map_icons",
  "info": {
    "singularName": "map-icon",
    "pluralName": "map-icons",
    "displayName": "map-icon"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "game": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::game.game"
    },
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "uuid": {
      "type": "customField",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "customField": "plugin::strapi-advanced-uuid.uuid",
      "options": {
        "disable-auto-fill": true,
        "uuid-format": "^Mi[a-zA-Z0-9]{5}$"
      }
    },
    "icon": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    }
  }
}
