{
  "kind": "collectionType",
  "collectionName": "quest_acts",
  "info": {
    "singularName": "quest-act",
    "pluralName": "quest-acts",
    "displayName": "quest-act"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "game": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::game.game"
    },
    "order": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "icon": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "uuid": {
      "type": "customField",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "customField": "plugin::strapi-advanced-uuid.uuid",
      "options": {
        "uuid-format": "^Qa[a-zA-Z0-9]{4}$",
        "disable-auto-fill": true
      }
    }
  }
}
