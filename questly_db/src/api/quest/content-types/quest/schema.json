{
  "kind": "collectionType",
  "collectionName": "quests",
  "info": {
    "singularName": "quest",
    "pluralName": "quests",
    "displayName": "quest"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "level": {
      "type": "integer"
    },
    "description": {
      "type": "richtext"
    },
    "short_desc": {
      "type": "string"
    },
    "map": {
      "type": "component",
      "component": "map.map",
      "repeatable": false
    },
    "tags": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tag.tag"
    },
    "rewards": {
      "type": "component",
      "component": "reward.reward",
      "repeatable": false
    },
    "requirement": {
      "type": "component",
      "component": "requirement.requirement",
      "repeatable": true
    },
    "game": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::game.game"
    },
    "character": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::character.character"
    },
    "location": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::location.location"
    },
    "quest_type": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::quest-type.quest-type"
    },
    "quest_act": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::quest-act.quest-act"
    },
    "quest_groups": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::quest-group.quest-group"
    },
    "uuid": {
      "type": "customField",
      "customField": "plugin::strapi-advanced-uuid.uuid",
      "options": {
        "uuid-format": "^Q[a-zA-Z0-9]{5}$"
      }
    },
    "dlc": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::dlc.dlc"
    }
  }
}
